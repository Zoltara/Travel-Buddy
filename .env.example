# ─────────────────────────────────────────────────────────────────────────────
# Travel Buddy – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Neon serverless Postgres connection string
# https://console.neon.tech → your project → Connection Details
NEON_DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/travelbuddy?sslmode=require"

# ── OpenRouter (LLM-powered resort search) ───────────────────────────────────
# Sign up free at https://openrouter.ai → Dashboard → Keys → Create Key
# Models: openai/gpt-4o-mini (default, cheap), anthropic/claude-3-haiku, google/gemini-flash-1.5
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_MODEL="openai/gpt-4o-mini"

# ── API Server ────────────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development

# ── Web App ───────────────────────────────────────────────────────────────────
# Public URL of the Fastify API (used by Next.js server components)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ── Mobile App ────────────────────────────────────────────────────────────────
# Set this in apps/mobile/.env
EXPO_PUBLIC_API_URL="http://localhost:4000"
