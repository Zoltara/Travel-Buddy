# ─────────────────────────────────────────────────────────────────────────────
# Travel Buddy – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Neon serverless Postgres connection string
# https://console.neon.tech → your project → Connection Details
NEON_DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/travelbuddy?sslmode=require"

# ── Google Maps (Places API for real resort search) ─────────────────────────
# Create a key at https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API (legacy) — the free tier covers ~2,500 searches/day
GOOGLE_MAPS_API_KEY="AIza..."

# ── API Server ────────────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development

# ── Web App ───────────────────────────────────────────────────────────────────
# Public URL of the Fastify API (used by Next.js server components)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ── Mobile App ────────────────────────────────────────────────────────────────
# Set this in apps/mobile/.env
EXPO_PUBLIC_API_URL="http://localhost:4000"
